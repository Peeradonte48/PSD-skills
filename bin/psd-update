#!/usr/bin/env bash
# psd-update — pull the latest PSD suite and re-run install.
# Only meaningful for curl-installed copies (~/.psd-skills). Plugin users
# should run /plugin update psd@PSD-skills inside Claude Code instead.
set -euo pipefail

PSD_HOME="${PSD_HOME:-$HOME/.psd-skills}"

if [ ! -d "$PSD_HOME/.git" ]; then
  echo "psd-update: $PSD_HOME is not a git checkout."
  echo "If you installed PSD as a Claude Code plugin, run:"
  echo "  /plugin update psd@PSD-skills"
  echo "inside Claude Code instead."
  exit 0
fi

echo "Pulling latest PSD from $PSD_HOME..."
git -C "$PSD_HOME" pull --ff-only
echo "Re-running installer..."
bash "$PSD_HOME/install.sh"
